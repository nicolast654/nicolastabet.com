---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import FormattedDate from "../../components/FormattedDate.astro";

// One page per post. Drafts are excluded from the production build but stay
// reachable in `astro dev` so they can be previewed while being written.
export const getStaticPaths = (async () => {
  const posts = await getCollection("blog", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  );
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description} article>
  <article>
    <header class="post-head">
      <h1>{post.data.title}</h1>
      <div class="meta">
        <FormattedDate date={post.data.pubDate} />
        {
          post.data.tags.length > 0 && (
            <ul class="tags">
              {post.data.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
          )
        }
      </div>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .post-head {
    margin-bottom: var(--space-12);
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-3) var(--space-4);
    margin-top: var(--space-4);
    color: var(--text-muted);
    font-size: var(--text-sm);
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
  }
  .tags li {
    font-family: var(--font-mono);
    background: var(--bg-subtle);
    border-radius: 4px;
    padding: 0.1em 0.5em;
  }
</style>
