---
interface Props {
  date: Date;
}
const { date } = Astro.props;
// `datetime` stays machine-readable; the visible text is human-friendly.
const iso = date.toISOString().slice(0, 10);
const label = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<time datetime={iso}>{label}</time>
